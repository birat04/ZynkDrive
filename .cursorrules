// //
// # ZynkDrive — Full Stack SaaS Development System Prompt

// ## Project Overview
// You are helping build ZynkDrive — a cloud storage and file sharing SaaS platform built with Next.js 15, React 19, Appwrite, TailwindCSS, ShadCN, and TypeScript. The reference implementation is adrianhajdin/storage_management_solution on GitHub. Always write production-quality, fully typed TypeScript code.

// ---

// ## Tech Stack
// - Framework: Next.js 15 (App Router, Server Actions)
// - UI: React 19, TailwindCSS, ShadCN/UI
// - Backend/Auth/Storage: Appwrite (cloud.appwrite.io)
// - Language: TypeScript (strict mode)
// - Font: Poppins (via next/font)
// - Charts: Recharts
// - Deployment: Vercel

// ---

// ## Environment Variables
// Always reference these — never hardcode values:
// NEXT_PUBLIC_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
// NEXT_PUBLIC_APPWRITE_PROJECT=""
// NEXT_PUBLIC_APPWRITE_DATABASE=""
// NEXT_PUBLIC_APPWRITE_USERS_COLLECTION=""
// NEXT_PUBLIC_APPWRITE_FILES_COLLECTION=""
// NEXT_PUBLIC_APPWRITE_BUCKET=""
// NEXT_APPWRITE_KEY=""

// ---

// ## Project Structure
// /app
//   /(auth)
//     /sign-in/page.tsx
//     /sign-up/page.tsx
//     layout.tsx
//   /(root)
//     /[type]/page.tsx        ← documents, images, media, others
//     layout.tsx
//     page.tsx                ← dashboard
// /components
//   ActionDropdown.tsx
//   ActionsModalContent.tsx
//   AuthForm.tsx
//   Card.tsx
//   Chart.tsx
//   FileUploader.tsx
//   FormattedDateTime.tsx
//   Header.tsx
//   MobileNavigation.tsx
//   OTPModal.tsx
//   Search.tsx
//   Sidebar.tsx
//   Thumbnail.tsx
//   Sort.tsx
// /constants
//   index.ts
// /hooks
//   useDebounce.ts
// /lib
//   appwrite/
//     index.ts               ← client + server Appwrite instances
//   actions/
//     file.actions.ts        ← uploadFile, getFiles, renameFile, deleteFile, updateFileUsers, getTotalSpaceUsed
//     user.actions.ts        ← createAccount, verifySecret, getCurrentUser, signOutUser, signInUser
//   utils.ts
// /types
//   index.d.ts
// /public
//   /assets/icons/           ← full SVG icon set

