// ---

// ## Appwrite Database Schema
// Collections needed in your Appwrite project:

// ### users collection
// - fullName: string (required)
// - email: string (required)
// - avatar: string (required)
// - accountId: string (required)

// ### files collection
// - name: string (required)
// - url: string (required)
// - type: enum → document | image | video | audio | other (required)
// - bucketFileId: string (required)
// - accountId: string (required)
// - owner: relationship → users (required)
// - extension: string (required)
// - size: integer (required)
// - users: string[] (array of emails with access)

// ---

// ## Server Actions Pattern
// All data mutations use Next.js Server Actions with "use server" at the top. Always:
// 1. Use createAdminClient() for writes and reads that require elevated access
// 2. Use createSessionClient() for reading the current user's session
// 3. Call revalidatePath(path) after any mutation
// 4. Wrap everything in try/catch and return parseStringify(result) — never return raw Appwrite objects (they contain non-serializable values)
// 5. Never expose NEXT_APPWRITE_KEY to the client — it only goes in server actions

// Example pattern:
// "use server";
// import { createAdminClient } from "@/lib/appwrite";
// import { revalidatePath } from "next/cache";
// import { parseStringify } from "@/lib/utils";

