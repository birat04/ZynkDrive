//       fileId,
//       { name: `${name}.${extension}` }
//     );
//     revalidatePath(path);
//     return parseStringify(updatedFile);
//   } catch (error) {
//     console.error(error);
//   }
// };

// ---

// ## Authentication Flow
// ZynkDrive uses Appwrite email OTP (no passwords):

// 1. User enters email → createAccount() or signInUser() is called
// 2. Appwrite sends a 6-digit OTP to the email
// 3. OTPModal component renders — user enters the code
// 4. verifySecret() is called → creates a session → sets "appwrite-session" cookie
// 5. User is redirected to dashboard

// Key functions in lib/actions/user.actions.ts:
// - createAccount: creates Appwrite account + user document, sends OTP
// - signInUser: finds existing user by email, sends OTP
// - verifySecret: verifies OTP, creates session cookie
// - getCurrentUser: reads session cookie, fetches user document from DB
// - signOutUser: deletes session, clears cookie

// Session cookie name: "appwrite-session"
// After verifySecret, set cookie like:
// (await cookies()).set("appwrite-session", session.secret, {
//   path: "/",
//   httpOnly: true,
//   sameSite: "strict",
//   secure: true,
// });

// ---

// ## File Upload Flow
// 1. User drops/selects files in FileUploader (react-dropzone)
// 2. Client calls uploadFile() server action for each file
// 3. uploadFile():
//    a. Calls storage.createFile() with InputFile.fromBuffer()
//    b. Constructs the view URL using constructFileUrl()
//    c. Creates a document in the files collection with metadata
//    d. Calls revalidatePath()
// 4. FileUploader shows a fixed bottom-right preview panel with upload progress
// 5. MAX_FILE_SIZE = 50MB enforced client-side before upload

// ---

// ## File Operations (ActionDropdown)
// The ActionDropdown component handles 5 actions via a ShadCN Dialog/AlertDialog:
// - rename: updates document name field in files collection
// - details: shows read-only file metadata (ActionsModalContent)
// - share: updates the users[] array on the file document (add/remove emails)
// - download: uses constructDownloadUrl() to trigger browser download
// - delete: calls storage.deleteFile() + databases.deleteDocument()

// State shape inside ActionDropdown:
// const [action, setAction] = useState<ActionType | null>(null);
// const [name, setName] = useState(file.name);
// const [isLoading, setIsLoading] = useState(false);
// const [emails, setEmails] = useState<string[]>([]);

// ---

// ## Dashboard Data
// getTotalSpaceUsed() server action queries ALL files for the current user and groups them:
// {
//   document: { size: number, latestDate: string },
//   image:    { size: number, latestDate: string },
//   video:    { size: number, latestDate: string },
//   audio:    { size: number, latestDate: string },
//   other:    { size: number, latestDate: string },
//   used: number,   // total bytes used
//   all: Models.Document[],  // last 10 files for recent list
// }
// Pass this to getUsageSummary() to get the 4 summary cards array.
// The Chart component receives "used" bytes and renders a Recharts RadialBarChart.
// Total quota = 2GB (2 * 1024 * 1024 * 1024 bytes).

// ---

// ## Routing & Pages
// /(auth) routes are public — redirect to "/" if user is already logged in
// /(root) routes are protected — redirect to "/sign-in" if no session

// /                 → Dashboard (getTotalSpaceUsed + getFiles limit:10)
// /documents        → getFiles({ types: ["document"] })
// /images           → getFiles({ types: ["image"] })
// /media            → getFiles({ types: ["video", "audio"] })
// /others           → getFiles({ types: ["other"] })

// All type pages use the same [type]/page.tsx and read searchParams for:
// - searchText: string  → passed to getFiles
// - sort: string        → "$createdAt-desc" default

// ---

// ## Search
// - Search component is in the Header (desktop) and MobileNavigation
// - Uses useDebounce(query, 300) before triggering getFiles
// - Results appear in a floating panel below the input (absolute positioned)
// - Searches across ALL file types regardless of current page
// - Uses router.push with ?searchText= query param to update results

// ---

// ## Component Conventions
// - All components are in /components at the root level (not /app)
// - Use "use client" only when needed (event handlers, hooks, browser APIs)
// - Server Components by default — fetch data at the page level and pass as props
// - ShadCN components are imported from @/components/ui/
// - Always use the cn() utility for conditional classNames
// - Thumbnail component: shows file type icon for documents/other, actual image preview for images
// - FormattedDateTime: small reusable component wrapping formatDateTime()
// - Card component: clickable file card used in the grid on type pages

// ---

// ## Tailwind Design Tokens
// Brand color: #FA7275 (brand) / #EA6365 (brand-100)
// Text scale: light-100 (#333F4E) → light-200 (#A3B2C7) → light-300/400 (backgrounds)
// Dark backgrounds: dark-100 (#04050C) / dark-200 (#131524)
// Shadows: shadow-drop-1, shadow-drop-2, shadow-drop-3
// All defined in tailwind.config.ts — never hardcode hex values in components.

// Key layout classes (defined in globals.css @layer utilities):
// - .main-content        → main scrollable area with rounded corners
// - .dashboard-container → 2-col responsive grid
// - .file-list           → 4-col responsive file card grid
// - .page-container      → max-w-7xl centered column
// - .primary-btn         → brand-colored rounded-full button
// - .flex-center         → flex items-center justify-center
// - .shad-no-focus       → removes all focus rings (used on inputs)
// - .h1 through .h5      → typography scale

// ---

// ## Code Quality Rules
// 1. TypeScript strict — no `any` except in getUsageSummary's totalSpace param (Appwrite returns untyped docs)
// 2. All server actions return parseStringify() results — never raw Appwrite objects
// 3. All async server actions wrapped in try/catch — log errors, don't throw to client
// 4. revalidatePath() called after every mutation
// 5. No inline styles — only Tailwind classes
// 6. No hardcoded strings — use constants/index.ts
// 7. No hardcoded colors — use Tailwind tokens from config
// 8. File size checks happen client-side (before upload) AND should be enforced in the Appwrite bucket settings
// 9. Image optimization: use next/image for all images, never <img>
// 10. Icons: use Next.js <Image> with the SVG paths from /public/assets/icons/

// ---

// ## Common Mistakes to Avoid
// - Never import from "appwrite" (client SDK) in server actions — use "node-appwrite"
// - Never call createSessionClient() without handling the "No session" error — it throws
// - Never return raw Appwrite Models.Document from server actions — always parseStringify()
// - Never put NEXT_APPWRITE_KEY in any client component or NEXT_PUBLIC_ variable
// - Never forget revalidatePath() after mutations — the UI won't update without it
// - Never use window or document in Server Components
// - The files collection "users" field is an array of email strings — not user IDs
// - Appwrite queries use Query.equal(), Query.contains(), Query.orderDesc() etc. — not raw SQL
// - When querying files for a user, filter by: Query.or([Query.equal("owner", [userId]), Query.contains("users", [email])])

// ---

